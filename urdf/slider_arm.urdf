<?xml version="1.0"?>
<robot name="6dof_cylinder_arm">

  <!-- ================= MATERIAL ================= -->
  <material name="gray">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>

  <xacro:include filename="$(find arctos_description)/urdf/materials.xacro" />
<xacro:include filename="$(find robot_arm)/urdf/simple_arm.trans" />
<xacro:include filename="$(find arctos_description)/urdf/arctos_urdf.gazebo" />

<link name="world"/>
<joint name="world_to_slider" type="fixed">
    <parent link="world"/>
    <child link="slider_link"/>
    <origin xyz="0 0 0" rpy="0 0 1.5708"/>
</joint>

<link name="slider_link">
    <inertial>
        <origin xyz="0 0 0.0" rpy="0 0 0"/>
        <mass value="20.0"/>
        <inertia ixx="0.1" iyy="1.0" izz="1.0" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
        <origin xyz="0 -0.26 0" rpy="0 0 -1.5708"/>
        <geometry>
            <mesh filename="package://arctos_description/meshes/slider_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="paint_metallic_blue_2"/>
    </visual>
    <collision>
        <origin xyz="0 -0.26 0.111" rpy="0 0 0"/>
        <geometry>
            <mesh filename="package://arctos_description/meshes/slider_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
    </collision>
</link>

<link name="slider_1">
    <inertial>
        <origin xyz="0 0 0.0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.05" iyy="0.05" izz="0.05" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
        <origin xyz="-0.25 0 -0.05" rpy="0 0 3.1416"/>
        <geometry>
            <mesh filename="package://arctos_description/meshes/slider_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="paint_metallic_blue_2"/>
    </visual>
    <collision>
        <origin xyz="-0.010 -0.245 0.1" rpy="0 0 -1.5708"/>
        <geometry>
            <mesh filename="package://arctos_description/meshes/slider_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
    </collision>
</link>


<joint name="slider_joint" type="prismatic">
    <parent link="slider_link"/>
    <child link="slider_1"/>
    <origin xyz="0 0 0.05" rpy="0 0 -1.5708"/>
    <axis xyz="0 1 0"/> <limit lower="0" upper="0.8" effort="1000" velocity="1.0"/> 
</joint>
  <!-- ================= BASE ================= -->
  <joint name="base_joint" type="fixed">
    <parent link="slider_1"/>
    <child link="base_link"/>
    <origin xyz="0 -0.02 0.05" rpy="0 0 0"/> </joint>

  <link name="base_link">
  <inertial>
    <origin xyz="0.0009375030874740357 0.047087016508753216 0.06663230338123677" rpy="0 0 0"/>
    <mass value="7.598577592821282"/>
    <inertia ixx="0.063328" iyy="0.03095" izz="0.072371" ixy="-0.000434" iyz="0.001366" ixz="0.000108"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 1.5708"/>
    <geometry>
      <mesh filename="package://arctos_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="paint_metallic_blue_2"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://arctos_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>


  <!-- ================= LINK 1 (L1 along Z) ================= -->
  <link name="link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.143935" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= LINK 2 (L2 along X) ================= -->
  <link name="link_2">
<!-- 0.05713 0.020356 -0.289378 -->
    <visual>
      <origin xyz="-0.289378 -0.020356  0.0 " rpy="0 -1.5708 3.1416"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0.13048 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= LINK 3 (L3 along X) ================= -->
  <link name="link_3">
  <!-- 0.043 0.019045 -0.550385 -->
    <visual>
      <origin xyz="0.019045 -0.550385 0" rpy="0 -1.5708 -1.5708"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0.13068 0" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
<!-- -1e-06 0.15874 -0.57209 -->
  <!-- ================= LINK 4 (small wrist rod) ================= -->
  <link name="link_4">
    <visual>
      <origin xyz="0 -0.57209 -0.15874" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- ================= LINK 5 ================= -->
  <link name="link_5">
  <!-- -0.039011 0.279927 -0.570316 -->
  <!-- -0.000193 -0.570316 -0.319847 -->
    <visual>
      <origin xyz="0.570316 0.279927 0.0" rpy="0 -1.5708 0"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_5_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>
  <!-- 0.000193 0.313762 -0.570316 -->
  <!-- ================= END EFFECTOR (D6 along Z) ================= -->
  <link name="ee_link">
    <visual>
      <origin xyz="0 -0.570316 -0.35" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="package://arctos_description/meshes/Link_6_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- ================= JOINT 1 ================= -->
  <!-- q1 -->
  <joint name="joint_1" type="continuous">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

  <!-- ================= JOINT 2 ================= -->
<joint name="joint_2" type="continuous">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.020885 0 0.28787" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

  <joint name="joint_3" type="continuous">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.26096 0 0" rpy="0 0 -3.1416"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>
  <!-- 0.021705 0.139695 0 -->
  <joint name="joint_4" type="continuous">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="-0.139695 0.02175 0" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>
<!-- -0.000193 -0.570316 -0.319847 -->
  <joint name="joint_5" type="continuous">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.12" rpy="-1.5708 0 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

  <joint name="joint_6" type="continuous">
    <parent link="link_5"/>
    <child link="ee_link"/>
    <origin xyz="0 -0.07074 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>
</robot>
